# Voice Cloning Platform Environment Variables

# Application Settings
APP_NAME=Voice Cloning Platform
APP_VERSION=1.0.0
DEBUG=true

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql://voice_user:voice_password@localhost:5432/voice_cloning

# Redis
REDIS_URL=redis://localhost:6379

# Storage Configuration
STORAGE_TYPE=local  # local, s3, gcs
LOCAL_STORAGE_PATH=./storage

# AWS S3 Configuration (if using S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-voice-cloning-bucket

# Google Cloud Storage Configuration (if using GCS)
GCS_PROJECT_ID=your_gcs_project_id
GCS_BUCKET_NAME=your-voice-cloning-bucket
GCS_CREDENTIALS_PATH=./gcs-credentials.json

# ML Models
MODEL_CACHE_DIR=./models
MAX_AUDIO_DURATION=600
SUPPORTED_AUDIO_FORMATS=.wav,.mp3,.flac,.m4a

# Training Configuration
MAX_TRAINING_DURATION=3600
MIN_VOICE_SAMPLES=5
MAX_VOICE_SAMPLES=50

# API Configuration
API_PREFIX=/api/v1
CORS_ORIGINS=*

# Hugging Face Spaces (for frontend deployment)
HF_TOKEN=your_huggingface_token
HF_SPACE_NAME=your-username/voice-cloning-platform

# Monitoring and Logging
LOG_LEVEL=INFO
ENABLE_METRICS=true
ENABLE_HEALTH_CHECKS=true

# Optional: External Services
STRIPE_SECRET_KEY=your_stripe_secret_key  # For billing
SENDGRID_API_KEY=your_sendgrid_api_key    # For email notifications